# Copy this file to `secrets.properties` (gitignored) and fill in values.
# Production builds ignore these — they are bundled into debug builds only.

# Bundled dev key for Brave Search API. Engineers obtain their own key from
# https://brave.com/search/api/ and paste it here. Production users provide their
# own key via the Settings screen.
BRAVE_DEV_KEY=

# Gemma 4 E2B (LiteRT-LM) artifact. The HuggingFace model card lives at
# https://huggingface.co/litert-community/gemma-4-E2B-it-litert-lm and the
# direct artifact URL has the form below. The repo is gated, so the engineer
# needs to (a) accept the license on the HF UI under their HF account, then
# (b) drop a read-scoped HF API token here so debug builds can download it
# without going through the onboarding token-entry screen.
#
# Production users supply their own token through the onboarding flow or
# Settings (BYOK, same pattern as Brave Search). Release builds always ship
# with an empty HF_AUTH_TOKEN BuildConfig field; HfAuthTokenProvider prefers
# the user-supplied token in SecureStorage and only falls back to BuildConfig
# on INTERNAL_BUILD (debug) builds.
MODEL_DOWNLOAD_URL=https://huggingface.co/litert-community/gemma-4-E2B-it-litert-lm/resolve/main/gemma-4-E2B-it.litertlm
MODEL_SHA256=181938105e0eefd105961417e8da75903eacda102c4fce9ce90f50b97139a63c
MODEL_SIZE_BYTES=2588147712
HF_AUTH_TOKEN=

# Release signing (all optional). When RELEASE_STORE_FILE is set, `:androidApp`'s
# release build is signed with this keystore so `./gradlew :androidApp:installRelease`
# installs directly. When these are left blank, the build falls back to the local
# Android debug keystore (~/.android/debug.keystore) so installRelease still works for
# on-device testing of the minified build — a debug-signed release is for LOCAL
# VERIFICATION ONLY, never for distribution (Play needs a real upload key). If no
# keystore exists at all the release is left unsigned.
RELEASE_STORE_FILE=
RELEASE_STORE_PASSWORD=
RELEASE_KEY_ALIAS=
RELEASE_KEY_PASSWORD=
